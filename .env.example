# Copy this file to .env and fill in real values
# DO NOT commit .env to version control

# Primary database connection used by Prisma
DATABASE_URL="postgresql://user:password@localhost:5432/blogdb?sslmode=require"

# NextAuth / Auth.js
AUTH_URL="https://cookingblogofivo.eu"
AUTH_SECRET="replace_with_a_strong_secret"

# Mailer (nodemailer) — required for password reset and email verification
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_USER="your-smtp-user"
SMTP_PASS="your-smtp-pass"

# Google OAuth (optional)
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Sentry (optional)
SENTRY_DSN=""

# CSP report-only mode (set to 1 in staging)
CSP_REPORT_ONLY="0"
