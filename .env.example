# Copy this file to .env and fill in values from your Neon dashboard
# Example values are placeholders — replace with real connection strings

# Primary database connection used by Prisma and the app
DATABASE_URL="postgresql://<user>:<password>@<host>:5432/<database>?sslmode=require"

# Optional shadow database used by Prisma Migrate (recommended)
# Use a separate Neon branch/database for the shadow DB
SHADOW_DATABASE_URL="postgresql://<user>:<password>@<host>:5432/<shadow_database>?sslmode=require"

# NextAuth secret (if used)
NEXTAUTH_SECRET="replace_with_a_strong_secret"
